generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  bio           String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  printLayouts  PrintLayout[]
}

model Device {
  id               String      @id @default(cuid())
  name             String
  description      String?
  photoUrl         String?
  isPublicPhoto    Boolean     @default(false)
  appriseUrl       String?
  appriseUrls      Json?
  includeBio       Boolean     @default(true)
  uniqueCode       String      @unique
  qrSettings       Json?
  lastScanViewedAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  messages         Message[]
  scans            DeviceScan[]
}

model QrTheme {
  id        String   @id @default(cuid())
  name      String
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id           String   @id @default(cuid())
  deviceId     String
  nickname     String
  message      String
  isOwnerReply Boolean  @default(false)
  createdAt    DateTime @default(now())
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model DeviceScan {
  id        String   @id @default(cuid())
  deviceId  String
  createdAt DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model AppriseEndpoint {
  id        String   @id @default(cuid())
  name      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrintLayout {
  id        String   @id @default(cuid())
  userId    String
  name      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
